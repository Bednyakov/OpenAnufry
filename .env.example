# ============================================
# AgentAnufry - Примеры конфигураций
# ============================================
# Скопируйте этот файл в .env и раскомментируйте нужную конфигурацию

# ============================================
# OpenAI (облако)
# ============================================
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4

# ============================================
# OpenRouter (облако, множество моделей)
# ============================================
# LLM_PROVIDER=openrouter
# LLM_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-3.5-sonnet

# ============================================
# Ollama (локально, рекомендуется)
# ============================================
# Установка: curl -fsSL https://ollama.com/install.sh | sh
# Запуск: ollama pull llama3.2 && ollama serve
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# ============================================
# LM Studio (локально, с GUI)
# ============================================
# Установка: https://lmstudio.ai
# Запустите LM Studio и включите Local Server
# LLM_PROVIDER=lmstudio
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=local-model
# LLM_API_KEY=lm-studio

# ============================================
# LocalAI (локально, Docker)
# ============================================
# Запуск: docker run -p 8080:8080 -v $PWD/models:/models quay.io/go-skynet/local-ai:latest
# LLM_PROVIDER=localai
# LLM_BASE_URL=http://localhost:8080/v1
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_KEY=local-ai

# ============================================
# vLLM (локально, высокая производительность)
# ============================================
# Установка: pip install vllm
# Запуск: python -m vllm.entrypoints.openai.api_server --model meta-llama/Llama-3.2-3B-Instruct --port 8000
# LLM_PROVIDER=vllm
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
# LLM_API_KEY=vllm

# ============================================
# Text Generation WebUI (oobabooga)
# ============================================
# Установка: https://github.com/oobabooga/text-generation-webui
# Включите OpenAI extension в настройках
# LLM_PROVIDER=textgen
# LLM_BASE_URL=http://localhost:5000/v1
# LLM_MODEL=text-generation-webui
# LLM_API_KEY=textgen

# ============================================
# Дополнительные параметры
# ============================================
# Температура генерации (0.0 = детерминированный, 1.0 = креативный)
LLM_TEMPERATURE=0.1

# Максимальное количество токенов в ответе
LLM_MAX_TOKENS=4096

# Таймаут запроса в секундах (важно для локальных моделей)
LLM_TIMEOUT=300

# Максимальное количество итераций агента
MAX_ITERATIONS=20

# ============================================
# Embeddings для памяти агента (опционально)
# ============================================
# Используйте OpenAI embeddings (по умолчанию)
# EMBEDDINGS_PROVIDER=openai
# EMBEDDINGS_MODEL=text-embedding-3-small
# EMBEDDINGS_BASE_URL=https://api.openai.com/v1

# Или локальные embeddings (требует установки sentence-transformers)
# EMBEDDINGS_PROVIDER=local
# LOCAL_EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================
# Безопасность
# ============================================
# Разрешенные команды (* = все, или список через запятую)
ALLOWED_COMMANDS=*

# ============================================
# Быстрый старт с Ollama
# ============================================
# 1. Установите Ollama: curl -fsSL https://ollama.com/install.sh | sh
# 2. Загрузите модель: ollama pull llama3.2
# 3. Раскомментируйте конфигурацию Ollama выше
# 4. Запустите: python main.py
